# Copy to .env on the server, then run: ./run-on-server.sh
# Required for Docker: DB_HOST=db, REDIS_HOST=redis (run-on-server.sh sets these if missing)

APP_NAME=Laravel
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=http://197.250.35.61:8084

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=kibo_v12
DB_USERNAME=kibo_user
DB_PASSWORD=your_secure_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail, Twilio, etc. – copy from your local .env as needed
